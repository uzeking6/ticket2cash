    async function loadSettings() {
        const data = await requestJson(`${API}/api/settings`);
        renderTable("settings-table", data);

        data.forEach(item => {
            if (item.settingKey === "TICKET_SIMULATED_AMOUNT") {
                document.getElementById("settingTicketAmount").value = item.settingValue;
            }

            if (item.settingKey === "DEFAULT_CURRENCY") {
                document.getElementById("settingCurrency").value = item.settingValue;
            }

            if (item.settingKey === "FRAUD_NORMAL_SCORE") {
                document.getElementById("settingNormalScore").value = item.settingValue;
            }

            if (item.settingKey === "FRAUD_DUPLICATE_SCORE") {
                document.getElementById("settingDuplicateScore").value = item.settingValue;
            }

            if (item.settingKey === "ANTI_FRAUD_ENABLED") {
                document.getElementById("settingAntiFraud").value = item.settingValue;
            }

            if (item.settingKey === "DEFAULT_ACTOR") {
                document.getElementById("settingActor").value = item.settingValue;
            }
        });
    }

    async function updateSettingValue(key, value) {
        return await requestJson(`${API}/api/settings/${key}?value=${encodeURIComponent(value)}`, {
            method: "PUT"
        });
    }

    async function saveSettings() {
        try {
            const results = [];

            results.push(await updateSettingValue("TICKET_SIMULATED_AMOUNT", document.getElementById("settingTicketAmount").value));
            results.push(await updateSettingValue("DEFAULT_CURRENCY", document.getElementById("settingCurrency").value));
            results.push(await updateSettingValue("FRAUD_NORMAL_SCORE", document.getElementById("settingNormalScore").value));
            results.push(await updateSettingValue("FRAUD_DUPLICATE_SCORE", document.getElementById("settingDuplicateScore").value));
            results.push(await updateSettingValue("ANTI_FRAUD_ENABLED", document.getElementById("settingAntiFraud").value));
            results.push(await updateSettingValue("DEFAULT_ACTOR", document.getElementById("settingActor").value));

            document.getElementById("settingsResponse").innerText = JSON.stringify(results, null, 2);

            await loadSettings();
            await loadDashboard();

        } catch (error) {
            document.getElementById("settingsResponse").innerText = JSON.stringify(error, null, 2);
        }
    }
    async function refreshAll() {
        await loadDashboard();
        await loadMerchants();
        await loadProducts();
        await loadCampaigns();
        await loadTickets();
        await loadClaims();
        await loadPayments();
        await loadFraudAlerts();
    }

    loadDashboard();
</script>

