        { key: "campaigns", text: "Campagnes" },
        { key: "tickets", text: "Tickets" },
        { key: "claims", text: "Claims" },
        { key: "payments", text: "Paiements cashback" },
        { key: "fraud", text: "Alertes fraude" },
        { key: "auditLogs", text: "Logs transactions" },
        { key: "settings", text: "Parametres" },
        { key: "users", text: "Utilisateurs" },
        { key: "exports", text: "Exports CSV" }
    ];

    function sidebar() {
        return document.querySelector("aside") || document.querySelector(".sidebar") || document.querySelector("nav");
    }

    function sectionExists(id) {
        return !!document.getElementById(id);
    }

    function buildSidebar() {
        const sb = sidebar();
        if (!sb) return;

        const oldButtons = Array.from(sb.querySelectorAll("button"));
        const existing = oldButtons.map(btn => {
            const onclick = btn.getAttribute("onclick") || "";
            const match = onclick.match(/showSection\('([^']+)'\)/);
            return match ? match[1] : null;
        }).filter(Boolean);

        sb.innerHTML = "";

        const brand = document.createElement("div");
        brand.className = "t2c-capture-brand";
        brand.innerHTML =
            '<img class="t2c-capture-logo" ' +
            'src="/assets/logo-ticket2cash.png" ' +
            'alt="Ticket2Cash" ' +
            'onerror="this.style.display=\'none\'; this.parentElement.querySelector(\'.t2c-capture-logo-fallback\').style.display=\'block\';">' +
            '<div class="t2c-capture-logo-fallback">Ticket2Cash</div>';

        sb.appendChild(brand);

        const label = document.createElement("div");
        label.className = "t2c-menu-group-label";
        label.textContent = "ESPACE PARTENAIRE";
        sb.appendChild(label);

        menuItems.forEach(item => {
            if (!existing.includes(item.key) && !sectionExists(item.key)) return;

            const btn = document.createElement("button");
            btn.className = "t2c-menu-button";
            btn.dataset.sectionId = item.key;
            btn.setAttribute("onclick", "showSection('" + item.key + "')");

            const iconHtml = icons[item.key] || icons.dashboard;

            btn.innerHTML =
                '<span class="t2c-menu-icon">' + iconHtml + '</span>' +
                '<span class="t2c-menu-label">' + item.text + '</span>';

            btn.addEventListener("click", function () {
                markActive(item.key, item.text);
            });

            sb.appendChild(btn);
        });
    }

    function createTopbar() {
        document.querySelectorAll(".t2c-capture-topbar").forEach(e => e.remove());

        const topbar = document.createElement("div");
        topbar.className = "t2c-capture-topbar";
        topbar.innerHTML =
            '<div class="t2c-capture-user-area">' +
                '<span class="t2c-capture-user" id="t2cCaptureUser">admin - ADMIN</span>' +
                '<button class="t2c-capture-logout" onclick="logout()">Deconnexion</button>' +
            '</div>' +
            '<div class="t2c-capture-title" id="t2cCaptureTitle">Tableau de bord</div>' +
            '<div class="t2c-capture-right">' +
                '<img class="t2c-afriland-mini" src="/assets/logo-afriland.png" alt="Afriland First Bank" onerror="this.style.display=\'none\';">' +
            '</div>';

        document.body.appendChild(topbar);
    }

    function updateUser() {
        try {
            const user = window.CURRENT_USER || CURRENT_USER;
            const box = document.getElementById("t2cCaptureUser");

            if (box && user) {
                box.textContent = (user.username || "utilisateur") + " - " + (user.role || "");
            }
        } catch (e) {}
    }

    function markActive(sectionId, text) {
        document.querySelectorAll(".t2c-menu-button").forEach(btn => {
            btn.classList.toggle("t2c-active-menu", btn.dataset.sectionId === sectionId);
        });

        const title = document.getElementById("t2cCaptureTitle");

        if (title) {
            const btnLabel = document.querySelector('.t2c-menu-button[data-section-id="' + sectionId + '"] .t2c-menu-label');
            title.textContent = text || (btnLabel ? btnLabel.textContent.trim() : "Ticket2Cash");
        }

        updateUser();
    }

    function patchShowSection() {
        if (window.__captureShowSectionPatched) return;
        if (typeof window.showSection !== "function") return;

        const original = window.showSection;

        window.showSection = function (sectionId) {
            const result = original.apply(this, arguments);
            markActive(sectionId);
            return result;
        };

        window.__captureShowSectionPatched = true;
    }

    function init() {
        buildSidebar();
        createTopbar();
        patchShowSection();
        updateUser();

        const visible = Array.from(document.querySelectorAll("section.section"))
            .find(s => s.style.display !== "none" && !s.hidden);

        if (visible && visible.id) {
            markActive(visible.id);
        } else {
            markActive("dashboard", "Tableau de bord");
        }
    }

    document.addEventListener("DOMContentLoaded", init);
    setTimeout(init, 500);
    setTimeout(init, 1200);
})();
</script>




<script id="ticket2cash-operations-top-js">
(function () {
    const skipSections = {
        dashboard: true,
        businessDashboard: true,
        security: true,
        demoReport: true
    };

    function isMenuOrTopbarElement(el) {
        return !!(
            el.closest("aside") ||
            el.closest("nav") ||
            el.closest(".sidebar") ||
            el.closest(".t2c-capture-topbar") ||
            el.closest(".t2c-operation-panel") ||
            el.closest("table")
        );
    }

    function hasUsefulButton(container) {
        if (!container) return false;
        const btn = container.querySelector("button");
        return !!btn && !isMenuOrTopbarElement(btn);
    }

    function findDirectOperationBlocks(section) {
        const blocks = [];

        Array.from(section.children).forEach(function (child) {
            if (!child) return;
            if (child.classList && child.classList.contains("t2c-operation-panel")) return;
            if (child.classList && child.classList.contains("cards")) return;
            if (child.classList && child.classList.contains("response-box")) return;
            if (child.tagName === "TABLE") return;
            if (child.tagName === "H1" || child.tagName === "H2" || child.tagName === "H3") return;

            const isFormGrid = child.classList && child.classList.contains("form-grid");
            const isForm = child.tagName === "FORM";
            const isDirectButton = child.tagName === "BUTTON";
            const isButtonContainer = child.tagName === "DIV" && hasUsefulButton(child) && !child.querySelector("table");

            if (isFormGrid || isForm || isDirectButton || isButtonContainer) {
                blocks.push(child);
            }
        });

        return blocks;
    }

    function getInsertPoint(section) {
        const h3 = section.querySelector("h3");
        if (h3 && h3.parentElement === section) {
            return h3.nextSibling;
        }
        return section.firstChild;
    }

    function prepareSectionOperations(section) {
        if (!section || !section.id) return;
        if (skipSections[section.id]) return;
        if (section.dataset.opsPrepared === "true") return;

        const blocks = findDirectOperationBlocks(section);

        if (!blocks.length) {
            section.dataset.opsPrepared = "true";
            return;
        }

        const panel = document.createElement("div");
        panel.className = "t2c-operation-panel";
        panel.innerHTML = '<div class="t2c-operation-panel-title">Operations rapides</div>';

        blocks.forEach(function (block) {
            panel.appendChild(block);
        });

        section.insertBefore(panel, getInsertPoint(section));

        section.dataset.opsPrepared = "true";
    }

    function prepareAllSections() {
        document.querySelectorAll("section.section").forEach(function (section) {
            prepareSectionOperations(section);
        });
    }

    function scrollPageTop() {
        try {
            window.scrollTo({ top: 0, behavior: "smooth" });
        } catch (e) {
            window.scrollTo(0, 0);
        }
    }

    function patchShowSectionForOperations() {
        if (window.__t2cOperationsShowSectionPatched) return;
        if (typeof window.showSection !== "function") return;

        const original = window.showSection;

        window.showSection = function (sectionId) {
            const result = original.apply(this, arguments);

            setTimeout(function () {
                prepareAllSections();
                scrollPageTop();
            }, 80);

            return result;
        };

        window.__t2cOperationsShowSectionPatched = true;
    }

    function initOperationsTop() {
        prepareAllSections();
        patchShowSectionForOperations();
    }

    document.addEventListener("DOMContentLoaded", initOperationsTop);
    setTimeout(initOperationsTop, 500);
    setTimeout(initOperationsTop, 1200);
})();
</script>











<script id="ticket2cash-about-isolation-js">
(function () {
    const titles = {
        dashboard: "Tableau de bord",
        demoCenter: "Centre demo",
        businessDashboard: "Dashboard metier",
        security: "Dashboard securite",
        demoFlow: "Parcours demo",
        demoReport: "Rapport demo",
        about: "A propos",
        profile: "Mon profil",
        merchants: "Commercants",
        products: "Produits",
        campaigns: "Campagnes",
        tickets: "Tickets",
        claims: "Claims",
        payments: "Paiements cashback",
        fraud: "Alertes fraude",
        auditLogs: "Logs transactions",
        settings: "Parametres",
        users: "Utilisateurs",
        exports: "Exports CSV"
    };

    function aboutIcon() {
        return '<svg viewBox="0 0 24 24" aria-hidden="true">' +
               '<circle cx="12" cy="12" r="9"></circle>' +
               '<path d="M12 10v7"></path>' +
               '<path d="M12 7h.01"></path>' +
               '</svg>';
    }

    function cleanupAboutLeaks() {
        document.querySelectorAll(".about-title-block, .about-grid, .about-flow").forEach(function (el) {
            if (!el.closest("#about")) {
                el.remove();
            }
        });

        const aboutSections = Array.from(document.querySelectorAll("section#about"));
        if (aboutSections.length > 1) {
            aboutSections.slice(0, aboutSections.length - 1).forEach(function (el) {
                el.remove();
            });
        }
    }

    function ensureAboutMenu() {
        const sb = document.querySelector("aside") || document.querySelector(".sidebar") || document.querySelector("nav");
        if (!sb) return;

        let btn = sb.querySelector('.t2c-menu-button[data-section-id="about"]');

        if (!btn) {
            btn = document.createElement("button");
            btn.className = "t2c-menu-button";
            btn.dataset.sectionId = "about";
            btn.setAttribute("onclick", "showSection('about')");
            btn.innerHTML =
                '<span class="t2c-menu-icon">' + aboutIcon() + '</span>' +
                '<span class="t2c-menu-label">A propos</span>';

            const after = sb.querySelector('.t2c-menu-button[data-section-id="demoReport"]');
            if (after && after.nextSibling) {
                sb.insertBefore(btn, after.nextSibling);
            } else if (after) {
                sb.appendChild(btn);
            } else {
                sb.appendChild(btn);
            }
        }
    }

    function setTitle(sectionId) {
        const title = document.getElementById("t2cCaptureTitle");
        if (title) {
            title.textContent = titles[sectionId] || "Ticket2Cash";
        }
    }

    function setActiveMenu(sectionId) {
        document.querySelectorAll(".t2c-menu-button").forEach(function (btn) {
            btn.classList.toggle("t2c-active-menu", btn.dataset.sectionId === sectionId);
        });
    }

    function hideAbout() {
        document.body.classList.remove("about-page-active");
        const about = document.getElementById("about");
        if (about) {
            about.style.display = "none";
        }
    }

    function showAboutOnly() {
        cleanupAboutLeaks();

        document.querySelectorAll(".section").forEach(function (sec) {
            sec.style.display = "none";
        });

        const about = document.getElementById("about");
        if (about) {
            about.style.display = "block";
        }

        document.body.classList.add("about-page-active");
        setActiveMenu("about");
        setTitle("about");
        window.scrollTo(0, 0);
    }

    function patchShowSection() {
        if (window.__aboutIsolationPatchApplied) return;
        if (typeof window.showSection !== "function") return;

        const oldShowSection = window.showSection;

        window.showSection = function (sectionId) {
            if (sectionId === "about") {
                showAboutOnly();
                return;
            }

            hideAbout();

            const result = oldShowSection.apply(this, arguments);

            setTimeout(function () {
                hideAbout();
                cleanupAboutLeaks();
                setTitle(sectionId);
                setActiveMenu(sectionId);
            }, 80);

            return result;
        };

        window.__aboutIsolationPatchApplied = true;
    }

    function init() {
        cleanupAboutLeaks();
        ensureAboutMenu();
        patchShowSection();

        document.querySelectorAll('.t2c-menu-button:not([data-section-id="about"])').forEach(function (btn) {
            btn.addEventListener("click", function () {
                hideAbout();
            });
        });
    }

    document.addEventListener("DOMContentLoaded", init);
    setTimeout(init, 600);
    setTimeout(init, 1300);
    setTimeout(init, 2300);
})();
</script>

