        { key: "security", text: "Dashboard securite" },
        { key: "demoFlow", text: "Parcours demo" },
        { key: "demoReport", text: "Rapport demo" },
        { key: "profile", text: "Mon profil" },
        { key: "merchants", text: "Commercants" },
