    async function resetUserPassword() {
        const userId = document.getElementById("adminResetUserId").value;
        const newPassword = document.getElementById("adminResetPassword").value.trim();
        const confirmPassword = document.getElementById("adminResetConfirmPassword").value.trim();

        const responseBox = document.getElementById("usersResponse");

        if (!userId || !newPassword || !confirmPassword) {
            responseBox.innerText = "Erreur : ID utilisateur et mot de passe obligatoires.";
            return;
        }

        if (newPassword !== confirmPassword) {
            responseBox.innerText = "Erreur : le mot de passe et la confirmation sont differents.";
            return;
        }

        if (newPassword.length < 8) {
            responseBox.innerText = "Erreur : le mot de passe doit contenir au moins 8 caracteres.";
            return;
        }

        if (newPassword.includes(" ")) {
            responseBox.innerText = "Erreur : le mot de passe ne doit pas contenir d'espace.";
            return;
        }

        const body = {
            newPassword: newPassword
        };

        try {
            const data = await requestJson(`${API}/api/auth/users/${userId}/reset-password`, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
