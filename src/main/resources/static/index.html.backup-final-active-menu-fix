    border-radius: 0 !important;
    padding: 22px !important;
    margin-bottom: 22px !important;
    box-shadow: none !important;
}

h1, h2, h3 {
    color: #111111 !important;
    font-weight: 900 !important;
}

h3 {
    margin-top: 0 !important;
    margin-bottom: 18px !important;
    padding-bottom: 10px !important;
    border-bottom: 1px solid #E5E7EB !important;
    font-size: 24px !important;
}

/* Cartes plus proches back-office */
.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(215px, 1fr));
    gap: 14px;
    margin: 18px 0;
}

.card {
    background: #FFFFFF !important;
    border: 1px solid #E5E7EB !important;
    border-radius: 0 !important;
    padding: 16px !important;
    box-shadow: none !important;
}

.card:hover {
    background: #FAFAFA !important;
}

.card h4 {
    color: #111111 !important;
    font-size: 13px !important;
    text-transform: none !important;
    margin: 0 0 8px 0 !important;
    font-weight: 800 !important;
}

.card p[id],
.card .value {
    font-size: 25px !important;
    font-weight: 900 !important;
    color: #111111 !important;
}

/* Boutons dans contenu : Afriland */
.btn-primary,
.btn-success,
button:not(.t2c-capture-logout):not(.t2c-menu-button):not(.btn-dark):not(.btn-danger) {
    background: var(--afb-red) !important;
    color: white !important;
    border: none !important;
    border-radius: 0 !important;
    font-weight: 800 !important;
}

.btn-dark {
    background: var(--afb-gold) !important;
    color: #111111 !important;
    border: none !important;
    border-radius: 0 !important;
    font-weight: 800 !important;
}

.btn-danger {
    background: #9F1C24 !important;
    color: white !important;
    border: none !important;
    border-radius: 0 !important;
}

/* Formulaires */
input,
select,
textarea {
    border-radius: 0 !important;
    border: 1px solid #D1D5DB !important;
    background: #FFFFFF !important;
    color: #111111 !important;
}

input:focus,
select:focus,
textarea:focus {
    outline: 2px solid rgba(210, 38, 48, 0.22) !important;
    border-color: var(--afb-red) !important;
}

/* Tables */
table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border: 1px solid #E5E7EB;
    margin: 12px 0 24px 0;
    box-shadow: none !important;
}

th {
