    let CURRENT_USER = null;

    async function checkAuthentication() {
        try {
            const response = await fetch(`${API}/api/auth/me`);
            const text = await response.text();
            const me = text ? JSON.parse(text) : { authenticated: false };

            if (!me.authenticated) {
                window.location.href = "/login.html";
                return;
            }

            CURRENT_USER = me;
            renderAuthBar(me);
            applyRoleRules(me.role);
            applyUserMenuRules(me.role);
            applySecurityMenuRules(me.role);
            applyDemoCenterMenuRules(me.role);

            await loadDashboard();

        } catch (error) {
            window.location.href = "/login.html";
        }
    }

    function renderAuthBar(user) {
        if (document.getElementById("authBar")) {
            document.getElementById("authUserInfo").innerText =
                user.fullName + " | " + user.username + " | " + user.role;
            return;
        }

        const bar = document.createElement("div");
        bar.className = "topbar";
        bar.id = "authBar";

        bar.innerHTML = `
            <h3>Session utilisateur</h3>
            <p id="authUserInfo">${user.fullName} | ${user.username} | ${user.role}</p>
            <button class="btn btn-dark" onclick="logout()">Deconnexion</button>
        `;

        const main = document.querySelector("main.content");
        const cards = document.querySelector(".cards");

        main.insertBefore(bar, cards);
    }

    async function logout() {
        try {
            await fetch(`${API}/api/auth/logout`, { method: "POST" });
        } catch (error) {
        }

        window.location.href = "/login.html";
    }

    function hideButtonByOnclick(onclickValue) {
        document.querySelectorAll(`button[onclick="${onclickValue}"]`).forEach(btn => {
            btn.classList.add("role-hidden");
        });
    }

    function showButtonByOnclick(onclickValue) {
        document.querySelectorAll(`button[onclick="${onclickValue}"]`).forEach(btn => {
            btn.classList.remove("role-hidden");
        });
    }

    function hideMenuBySection(sectionName) {
        document.querySelectorAll(`button[onclick="showSection('${sectionName}')"]`).forEach(btn => {
            btn.classList.add("role-hidden");
        });
    }

    function showRoleNotice(message) {
        let notice = document.getElementById("roleNotice");

        if (!notice) {
            notice = document.createElement("div");
            notice.id = "roleNotice";
            notice.className = "role-notice";

            const topbar = document.querySelector(".topbar");
            topbar.parentNode.insertBefore(notice, topbar.nextSibling);
        }

        notice.innerText = message;
    }

    function applyRoleRules(role) {
        const adminOnlyActions = [
            "createMerchant()",
            "updateMerchantStatus()",
            "createProduct()",
            "createCampaign()",
            "updateCampaignStatus()",
            "saveSettings()",
            "createTestAuditLog()"
        ];

        const operatorActions = [
            "simulateOcr()",
            "approveClaim()",
            "runCashbackBatch()"
        ];

        adminOnlyActions.forEach(action => showButtonByOnclick(action));
        operatorActions.forEach(action => showButtonByOnclick(action));

        document.querySelectorAll(".role-hidden").forEach(el => {
            el.classList.remove("role-hidden");
        });

        if (role === "ADMIN") {
            showRoleNotice("Role ADMIN : acces complet a toutes les fonctionnalites.");
            return;
        }

        if (role === "OPERATEUR") {
            adminOnlyActions.forEach(action => hideButtonByOnclick(action));
            showRoleNotice("Role OPERATEUR : operations metier autorisees, creation et parametres reserves a ADMIN.");
            return;
        }

        if (role === "LECTEUR") {
            adminOnlyActions.forEach(action => hideButtonByOnclick(action));
            operatorActions.forEach(action => hideButtonByOnclick(action));
            showRoleNotice("Role LECTEUR : consultation uniquement. Les actions de creation, modification et paiement sont masquees.");
            return;
        }
    }

    function applyUserMenuRules(role) {
        document.querySelectorAll(`button[onclick="showSection('users')"]`).forEach(btn => {
            if (role === "ADMIN") {
                btn.classList.remove("role-hidden");
            } else {
                btn.classList.add("role-hidden");
            }
        });
    }

    function applySecurityMenuRules(role) {
        document.querySelectorAll(`button[onclick="showSection('security')"]`).forEach(btn => {
            if (role === "ADMIN") {
                btn.classList.remove("role-hidden");
            } else {
                btn.classList.add("role-hidden");
            }
