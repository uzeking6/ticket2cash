    }

    function applyDemoCenterMenuRules(role) {
        document.querySelectorAll(`button[onclick="showSection('demoCenter')"]`).forEach(btn => {
            if (role === "ADMIN") {
                btn.classList.remove("role-hidden");
            } else {
                btn.classList.add("role-hidden");
            }
        });
    }
    async function requestJson(url, options = {}) {
        const response = await fetch(url, options);
        const text = await response.text();

        let data;
        try {
            data = text ? JSON.parse(text) : {};
        } catch (e) {
            data = text;
        }

        if (!response.ok) {
            throw data;
        }

        return data;
    }

    function formatValue(value) {
        if (value === null || value === undefined) return "";
        if (typeof value === "object") return JSON.stringify(value);
        return value;
    }

    function formatStatus(value) {
        if (!value) return "";

        let css = "status-info";

        if (["SUCCESS", "PAID", "ACTIVE", "APPROVED", "RESOLVED"].includes(value)) css = "status-success";
        if (["SUBMITTED", "PENDING", "OPEN", "OCR_PENDING", "DRAFT"].includes(value)) css = "status-warning";
        if (["REJECTED", "FAILED", "PAYMENT_FAILED", "SUSPENDED"].includes(value)) css = "status-danger";

        return `<span class="status ${css}">${value}</span>`;
    }

    function renderTable(containerId, rows) {
        const container = document.getElementById(containerId);

        if (!rows || rows.length === 0) {
            container.innerHTML = "<p>Aucune donnee disponible.</p>";
            return;
        }

        if (!Array.isArray(rows)) rows = [rows];

        const columns = Object.keys(rows[0]);

        let html = '<div class="table-wrapper"><table><thead><tr>';

        columns.forEach(col => html += `<th>${col}</th>`);

        html += "</tr></thead><tbody>";

        rows.forEach(row => {
            html += "<tr>";
            columns.forEach(col => {
                const value = row[col];
                if (col.toLowerCase().includes("status")) {
                    html += `<td>${formatStatus(value)}</td>`;
                } else {
                    html += `<td>${formatValue(value)}</td>`;
                }
            });
            html += "</tr>";
        });

        html += "</tbody></table></div>";
        container.innerHTML = html;
    }

    function renderDashboardCards(summary) {
        const cards = [
            ["Commercants", summary.commercantsPartenaires || 0],
            ["Produits", summary.produitsCatalogues || 0],
            ["Claims", summary.claimsSoumis || 0],
            ["Cashback paye", `${summary.cashbackTotalPaye || 0} ${summary.devise || "FCFA"}`]
        ];

        let html = "";

        cards.forEach(card => {
            html += `
                <div class="card">
                    <div class="label">${card[0]}</div>
                    <div class="value">${card[1]}</div>
                </div>
            `;
        });

        document.getElementById("dashboard-cards").innerHTML = html;
