        claims: svg('<path d="M5 12l4 4L19 6"></path>'),
        payments: svg('<path d="M4 7h16v10H4V7z"></path><path d="M4 11h16"></path><path d="M8 15h4"></path>'),
        fraud: svg('<path d="M12 3l10 18H2L12 3z"></path><path d="M12 9v5"></path><path d="M12 17h.01"></path>'),
        auditLogs: svg('<path d="M5 4h14v16H5V4z"></path><path d="M8 8h8"></path><path d="M8 12h8"></path><path d="M8 16h5"></path>'),
