<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ticket2Cash</title>

    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            color: #1f2937;
        }

        .sidebar {
            width: 270px;
            background: #0f172a;
            color: white;
            padding: 20px;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            overflow-y: auto;
        }

        .sidebar h1 {
            margin: 0 0 8px 0;
            font-size: 24px;
        }

        .sidebar p {
            color: #cbd5e1;
            font-size: 13px;
            margin-bottom: 25px;
        }

        .menu button {
            width: 100%;
            display: block;
            padding: 12px;
            margin-bottom: 10px;
            border: none;
            border-radius: 8px;
            background: #1e293b;
            color: white;
            text-align: left;
            cursor: pointer;
            font-size: 14px;
        }

        .menu button:hover {
            background: #334155;
        }

        .content {
            margin-left: 270px;
            padding: 25px;
        }

        .topbar, .section, .card {
            background: white;
            border-radius: 6px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }

        .topbar {
            padding: 18px;
            margin-bottom: 20px;
        }

        .topbar h2 {
            margin: 0;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .card {
            padding: 18px;
        }

        .card .label {
            color: #64748b;
            font-size: 13px;
        }

        .card .value {
            font-size: 24px;
            font-weight: bold;
            margin-top: 8px;
        }

        .section {
            display: none;
            padding: 20px;
            margin-bottom: 20px;
        }

        .section.active {
            display: block;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin-bottom: 10px;
        }

        label {
            font-size: 13px;
            font-weight: bold;
            color: #334155;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin-top: 4px;
            margin-bottom: 10px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
        }

        .btn {
            padding: 11px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            margin-right: 6px;
            margin-bottom: 8px;
        }

        .btn-primary { background: #2563eb; color: white; }
        .btn-success { background: #16a34a; color: white; }
        .btn-dark { background: #111827; color: white; }

        .response-box {
            background: #0f172a;
            color: #e5e7eb;
            padding: 15px;
            border-radius: 4px;
            margin-top: 15px;
            white-space: pre-wrap;
            font-size: 13px;
            max-height: 300px;
            overflow: auto;
        }

        .table-wrapper {
            overflow-x: auto;
            margin-top: 15px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            min-width: 900px;
        }

        th {
            background: #f1f5f9;
            text-align: left;
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
        }

        .status {
            padding: 4px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            white-space: nowrap;
        }

        .status-success { background: #dcfce7; color: #166534; }
        .status-warning { background: #fef3c7; color: #92400e; }
        .status-danger { background: #fee2e2; color: #991b1b; }
        .status-info { background: #dbeafe; color: #1d4ed8; }

        @media (max-width: 900px) {
            .sidebar {
                position: relative;
                width: 100%;
            }

            .content {
                margin-left: 0;
            }

            .cards, .form-grid {
                grid-template-columns: 1fr;
            }
        }
            .role-hidden {
            display: none !important;
        }

        .role-notice {
            background: #fef3c7;
            color: #92400e;
            padding: 12px;
            border-radius: 4px;
            margin-bottom: 15px;
            font-size: 13px;
        }
</style>
















<style id="ticket2cash-real-capture-menu">
/* ==========================================================
   Ticket2Cash - Layout proche des captures envoyees
   Menu blanc, header noir, icones noires, actif gris
   ========================================================== */

:root {
    --t2c-sidebar-width: 220px;
    --t2c-topbar-height: 64px;
    --t2c-bg: #F7F7F7;
    --t2c-white: #FFFFFF;
    --t2c-black: #111111;
    --t2c-text: #222222;
    --t2c-muted: #6B7280;
    --t2c-border: #E5E7EB;
    --t2c-active: #E5E7EB;
    --afb-red: #D22630;
    --afb-gold: #FFCC00;
}

* {
    box-sizing: border-box;
}

body {
    margin: 0 !important;
    background: var(--t2c-bg) !important;
    color: var(--t2c-text);
    font-family: "Segoe UI", Arial, Helvetica, sans-serif;
}

/* CONTENU PRINCIPAL */
main {
    margin-left: var(--t2c-sidebar-width) !important;
    padding: 86px 26px 30px 26px !important;
    background: var(--t2c-bg) !important;
    min-height: 100vh !important;
}

/* SIDEBAR EXACTEMENT PLUS PROCHE DES CAPTURES */
aside,
.sidebar,
nav {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    bottom: 0 !important;
    width: var(--t2c-sidebar-width) !important;
    background: #FFFFFF !important;
    color: #222222 !important;
    border-right: 1px solid #DADDE2 !important;
    box-shadow: none !important;
    overflow-y: auto !important;
    z-index: 1000 !important;
    padding: 0 !important;
}

/* En-tete noir logo */
.t2c-capture-brand {
    height: 64px;
    background: #000000;
    display: flex;
    align-items: center;
    padding: 0 16px;
    border-bottom: 1px solid #222;
}

.t2c-capture-logo {
    max-height: 42px;
    max-width: 150px;
    object-fit: contain;
}

.t2c-capture-logo-fallback {
    color: white;
    font-size: 20px;
    font-weight: 900;
    display: none;
}

/* Label espace partenaire */
.t2c-menu-group-label {
    padding: 13px 16px 8px 16px;
    font-size: 11px;
    font-weight: 800;
    color: #6B7280;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: #FFFFFF;
}

/* Masquer les anciens titres du menu */
aside > h1,
aside > h2,
aside > h3,
.sidebar > h1,
.sidebar > h2,
.sidebar > h3,
nav > h1,
nav > h2,
nav > h3 {
    display: none !important;
}

/* Items du menu */
aside button,
.sidebar button,
nav button {
    width: 100% !important;
    height: 38px !important;
    display: flex !important;
    align-items: center !important;
    gap: 13px !important;
    margin: 0 !important;
    padding: 0 14px 0 22px !important;
    border: none !important;
    border-left: 4px solid transparent !important;
    border-radius: 0 !important;
    background: #FFFFFF !important;
    color: #333333 !important;
    text-align: left !important;
    font-size: 13px !important;
    font-weight: 700 !important;
