    async function runDemoFlow() {
        const responseBox = document.getElementById("demoFlowResponse");

        try {
            responseBox.innerText = "Execution du parcours en cours...";

            const data = await requestJson(`${API}/api/demo-flow/run`, {
                method: "POST"
            });

            responseBox.innerText =
                "Parcours execute avec succes.\n" +
                "Ticket : " + data.ticketNumber + "\n" +
                "Claim : " + data.claimReference + " / " + data.claimStatus + "\n" +
