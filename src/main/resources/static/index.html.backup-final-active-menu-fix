    background: #F0F1F3 !important;
    color: #111111 !important;
    border-left-color: #111111 !important;
}

/* Actif comme les captures : gris + trait noir */
aside button.t2c-active-menu,
.sidebar button.t2c-active-menu,
nav button.t2c-active-menu {
    background: #E3E5E8 !important;
