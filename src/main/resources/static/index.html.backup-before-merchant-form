<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ticket2Cash - Dashboard</title>

    <style>
        * { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            color: #1f2937;
        }

        .layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: #0f172a;
            color: white;
            padding: 20px;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            overflow-y: auto;
        }

        .sidebar h1 {
            font-size: 22px;
            margin: 0 0 5px 0;
        }

        .sidebar p {
            color: #94a3b8;
            font-size: 13px;
            margin-bottom: 25px;
        }

        .menu button {
            width: 100%;
            display: block;
            margin-bottom: 10px;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: #1e293b;
            color: white;
            text-align: left;
            cursor: pointer;
            font-size: 14px;
        }

        .menu button:hover {
            background: #334155;
        }

        .content {
            margin-left: 260px;
            flex: 1;
            padding: 25px;
        }

        .topbar {
            background: white;
            padding: 18px;
            border-radius: 12px;
            margin-bottom: 20px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }

        .topbar h2 {
            margin: 0;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 18px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
        }

        .card .label {
            color: #64748b;
            font-size: 13px;
        }

        .card .value {
            font-size: 24px;
            font-weight: bold;
            margin-top: 8px;
        }

        .section {
            display: none;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            margin-bottom: 20px;
        }

        .section.active {
            display: block;
        }

        .section h3 {
            margin-top: 0;
        }

        .table-wrapper {
            overflow-x: auto;
            margin-top: 15px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            min-width: 900px;
        }

        th {
            background: #f1f5f9;
            text-align: left;
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
            white-space: nowrap;
        }

        td {
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
            vertical-align: top;
        }

        .status {
            padding: 4px 8px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            white-space: nowrap;
        }

        .status-success { background: #dcfce7; color: #166534; }
        .status-warning { background: #fef3c7; color: #92400e; }
        .status-danger { background: #fee2e2; color: #991b1b; }
        .status-info { background: #dbeafe; color: #1d4ed8; }

        input, select {
            width: 100%;
            padding: 10px;
            margin-bottom: 12px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
        }

        label {
            font-size: 13px;
            font-weight: bold;
            color: #334155;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
        }

        .btn {
            padding: 11px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            margin-right: 6px;
            margin-bottom: 8px;
        }

        .btn-primary { background: #2563eb; color: white; }
        .btn-success { background: #16a34a; color: white; }
        .btn-dark { background: #111827; color: white; }

        .response-box {
            background: #0f172a;
            color: #e5e7eb;
            padding: 15px;
            border-radius: 10px;
            margin-top: 15px;
            white-space: pre-wrap;
            font-size: 13px;
            max-height: 300px;
            overflow: auto;
        }

        @media (max-width: 1100px) {
            .cards { grid-template-columns: repeat(2, 1fr); }
            .form-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 800px) {
            .sidebar {
                position: relative;
                width: 100%;
            }

            .content {
                margin-left: 0;
            }

            .layout {
                flex-direction: column;
            }

            .cards, .form-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

<div class="layout">

    <aside class="sidebar">
        <h1>Ticket2Cash</h1>
        <p>Cashback Supermarchés - Prototype DEI</p>

        <div class="menu">
            <button onclick="showSection('dashboard')">Tableau de bord</button>
            <button onclick="showSection('ocr')">Simulation OCR</button>
            <button onclick="showSection('merchants')">Commerçants</button>
            <button onclick="showSection('products')">Produits</button>
            <button onclick="showSection('campaigns')">Campagnes</button>
            <button onclick="showSection('tickets')">Tickets</button>
            <button onclick="showSection('claims')">Claims</button>
            <button onclick="showSection('payments')">Paiements cashback</button>
            <button onclick="showSection('fraud')">Alertes fraude</button>
        </div>
    </aside>

    <main class="content">

        <div class="topbar">
            <h2 id="page-title">Tableau de bord</h2>
            <p>Interface web de supervision du prototype Ticket2Cash.</p>
        </div>

        <div class="cards" id="dashboard-cards"></div>

        <section id="dashboard" class="section active">
            <h3>Résumé global</h3>
            <button class="btn btn-primary" onclick="loadDashboard()">Actualiser le dashboard</button>
            <button class="btn btn-dark" onclick="refreshAll()">Actualiser toutes les données</button>
            <div id="dashboard-table"></div>
        </section>

        <section id="ocr" class="section">
            <h3>Simulation OCR ticket</h3>

            <div class="form-grid">
                <div>
                    <label>Merchant ID</label>
                    <input id="ocrMerchantId" type="number" value="1">
                </div>

                <div>
                    <label>Campaign ID</label>
                    <input id="ocrCampaignId" type="number" value="1">
                </div>

                <div>
                    <label>User ID</label>
                    <input id="ocrUserId" type="text" value="demo_user_1">
                </div>

                <div>
                    <label>Numéro ticket</label>
                    <input id="ocrTicketNumber" type="text" value="TICKET-300">
                </div>
            </div>

            <button class="btn btn-primary" onclick="simulateOcr()">Lancer OCR simulé</button>
            <div class="response-box" id="ocrResponse">Aucune simulation lancée.</div>
        </section>

        <section id="merchants" class="section">
            <h3>Commerçants partenaires</h3>
            <button class="btn btn-primary" onclick="loadMerchants()">Actualiser</button>
            <div id="merchants-table"></div>
        </section>

        <section id="products" class="section">
            <h3>Catalogue produits</h3>

            <div class="form-grid">
                <div>
                    <label>Merchant ID</label>
                    <input id="productMerchantId" type="number" value="1">
                </div>

                <div>
                    <label>SKU</label>
                    <input id="productSku" type="text" value="RIZ-001">
                </div>

                <div>
                    <label>Nom produit</label>
                    <input id="productName" type="text" value="Riz parfumé 5KG">
                </div>

                <div>
                    <label>Désignation ticket</label>
                    <input id="productTicketDesignation" type="text" value="RIZ PARF 5KG">
                </div>

                <div>
                    <label>Catégorie</label>
                    <input id="productCategory" type="text" value="Alimentaire">
                </div>

                <div>
                    <label>Marque</label>
                    <input id="productBrand" type="text" value="Super Rice">
                </div>

                <div>
                    <label>Prix</label>
                    <input id="productPrice" type="number" value="8500">
                </div>

                <div>
                    <label>Type cashback</label>
                    <select id="productCashbackType">
                        <option value="PERCENTAGE">PERCENTAGE</option>
                        <option value="FIXED_AMOUNT">FIXED_AMOUNT</option>
                        <option value="NONE">NONE</option>
                    </select>
                </div>

                <div>
                    <label>Valeur cashback</label>
                    <input id="productCashbackValue" type="number" value="5">
                </div>
            </div>

            <button class="btn btn-success" onclick="createProduct()">Créer produit</button>
            <button class="btn btn-primary" onclick="loadProducts()">Actualiser</button>

            <div class="response-box" id="productResponse">Aucun produit créé depuis l’interface.</div>
            <div id="products-table"></div>
        </section>

        <section id="campaigns" class="section">
            <h3>Campagnes cashback</h3>
            <button class="btn btn-primary" onclick="loadCampaigns()">Actualiser</button>
            <div id="campaigns-table"></div>
        </section>

        <section id="tickets" class="section">
            <h3>Tickets OCR</h3>
            <button class="btn btn-primary" onclick="loadTickets()">Actualiser</button>
            <div id="tickets-table"></div>
        </section>

        <section id="claims" class="section">
            <h3>Claims cashback</h3>

            <div class="form-grid">
                <div>
                    <label>ID du claim à approuver</label>
                    <input id="claimIdToApprove" type="number" placeholder="Exemple : 1">
                </div>

                <div>
                    <label>Action</label><br>
                    <button class="btn btn-success" onclick="approveClaim()">Approuver le claim</button>
                </div>
            </div>

            <button class="btn btn-primary" onclick="loadClaims()">Actualiser</button>
            <div id="claims-table"></div>
        </section>

        <section id="payments" class="section">
            <h3>Paiements cashback</h3>

            <button class="btn btn-success" onclick="runCashbackBatch()">Lancer batch cashback J+1</button>
            <button class="btn btn-primary" onclick="loadPayments()">Actualiser paiements</button>

            <div class="response-box" id="batchResponse">Batch non lancé.</div>
            <div id="payments-table"></div>
        </section>

        <section id="fraud" class="section">
            <h3>Alertes fraude</h3>
            <button class="btn btn-primary" onclick="loadFraudAlerts()">Actualiser</button>
            <div id="fraud-table"></div>
        </section>

    </main>
</div>

<script>
    const API = "";

    function showSection(sectionId) {
        document.querySelectorAll(".section").forEach(section => section.classList.remove("active"));
        document.getElementById(sectionId).classList.add("active");

        const titles = {
            dashboard: "Tableau de bord",
            ocr: "Simulation OCR",
            merchants: "Commerçants",
            products: "Produits",
            campaigns: "Campagnes",
            tickets: "Tickets",
            claims: "Claims",
            payments: "Paiements cashback",
            fraud: "Alertes fraude"
        };

        document.getElementById("page-title").innerText = titles[sectionId] || "Ticket2Cash";

        if (sectionId === "dashboard") loadDashboard();
        if (sectionId === "merchants") loadMerchants();
        if (sectionId === "products") loadProducts();
        if (sectionId === "campaigns") loadCampaigns();
        if (sectionId === "tickets") loadTickets();
        if (sectionId === "claims") loadClaims();
        if (sectionId === "payments") loadPayments();
        if (sectionId === "fraud") loadFraudAlerts();
    }

    async function requestJson(url, options = {}) {
        const response = await fetch(url, options);
        const text = await response.text();

        let data;
        try {
            data = text ? JSON.parse(text) : {};
        } catch (e) {
            data = text;
        }

        if (!response.ok) {
            throw data;
        }

        return data;
    }

    function formatValue(value) {
        if (value === null || value === undefined) return "";
        if (typeof value === "object") return JSON.stringify(value);
        return value;
    }

    function formatStatus(value) {
        if (!value) return "";

        let css = "status-info";

        if (["SUCCESS", "PAID", "ACTIVE", "APPROVED", "RESOLVED"].includes(value)) {
            css = "status-success";
        }

        if (["SUBMITTED", "PENDING", "OPEN", "OCR_PENDING", "DRAFT"].includes(value)) {
            css = "status-warning";
        }

        if (["REJECTED", "FAILED", "PAYMENT_FAILED", "SUSPENDED"].includes(value)) {
            css = "status-danger";
        }

        return `<span class="status ${css}">${value}</span>`;
    }

    function renderTable(containerId, rows) {
        const container = document.getElementById(containerId);

        if (!rows || rows.length === 0) {
            container.innerHTML = "<p>Aucune donnée disponible.</p>";
            return;
        }

        if (!Array.isArray(rows)) {
            rows = [rows];
        }

        const columns = Object.keys(rows[0]);

        let html = '<div class="table-wrapper"><table><thead><tr>';

        columns.forEach(col => {
            html += `<th>${col}</th>`;
        });

        html += "</tr></thead><tbody>";

        rows.forEach(row => {
            html += "<tr>";

            columns.forEach(col => {
                const value = row[col];

                if (col.toLowerCase().includes("status")) {
                    html += `<td>${formatStatus(value)}</td>`;
                } else {
                    html += `<td>${formatValue(value)}</td>`;
                }
            });

            html += "</tr>";
        });

        html += "</tbody></table></div>";

        container.innerHTML = html;
    }

    function renderDashboardCards(summary) {
        const cards = [
            ["Commerçants", summary.commercantsPartenaires || 0],
            ["Produits", summary.produitsCatalogues || 0],
            ["Claims", summary.claimsSoumis || 0],
            ["Cashback payé", `${summary.cashbackTotalPaye || 0} ${summary.devise || "FCFA"}`]
        ];

        let html = "";

        cards.forEach(card => {
            html += `
                <div class="card">
                    <div class="label">${card[0]}</div>
                    <div class="value">${card[1]}</div>
                </div>
            `;
        });

        document.getElementById("dashboard-cards").innerHTML = html;
    }

    async function loadDashboard() {
        try {
            const data = await requestJson(`${API}/api/dashboard/summary`);
            renderDashboardCards(data);

            const rows = Object.keys(data).map(key => ({
                indicateur: key,
                valeur: data[key]
            }));

            renderTable("dashboard-table", rows);
        } catch (error) {
            document.getElementById("dashboard-table").innerHTML =
                `<div class="response-box">${JSON.stringify(error, null, 2)}</div>`;
        }
    }

    async function loadMerchants() {
        const data = await requestJson(`${API}/api/merchants`);
        renderTable("merchants-table", data);
    }

    async function loadProducts() {
        const data = await requestJson(`${API}/api/products`);
        renderTable("products-table", data);
    }

    async function createProduct() {
        const body = {
            merchantId: Number(document.getElementById("productMerchantId").value),
            sku: document.getElementById("productSku").value,
            name: document.getElementById("productName").value,
            ticketDesignation: document.getElementById("productTicketDesignation").value,
            synonyms: document.getElementById("productTicketDesignation").value,
            category: document.getElementById("productCategory").value,
            brand: document.getElementById("productBrand").value,
            price: Number(document.getElementById("productPrice").value),
            groupKey: document.getElementById("productCategory").value,
            cashbackType: document.getElementById("productCashbackType").value,
            cashbackValue: Number(document.getElementById("productCashbackValue").value),
            active: true
        };

        try {
            const data = await requestJson(`${API}/api/products`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });

            document.getElementById("productResponse").innerText = JSON.stringify(data, null, 2);

            await loadProducts();
            await loadDashboard();

        } catch (error) {
            document.getElementById("productResponse").innerText = JSON.stringify(error, null, 2);
        }
    }

    async function loadCampaigns() {
        const data = await requestJson(`${API}/api/campaigns`);
        renderTable("campaigns-table", data);
    }

    async function loadTickets() {
        const data = await requestJson(`${API}/api/tickets`);
        renderTable("tickets-table", data);
    }

    async function loadClaims() {
        const data = await requestJson(`${API}/api/claims`);
        renderTable("claims-table", data);
    }

    async function loadPayments() {
        const data = await requestJson(`${API}/api/cashback/payments`);
        renderTable("payments-table", data);
    }

    async function loadFraudAlerts() {
        const data = await requestJson(`${API}/api/fraud/alerts`);
        renderTable("fraud-table", data);
    }

    async function simulateOcr() {
        const body = {
            merchantId: Number(document.getElementById("ocrMerchantId").value),
            campaignId: Number(document.getElementById("ocrCampaignId").value),
            userId: document.getElementById("ocrUserId").value,
            ticketNumber: document.getElementById("ocrTicketNumber").value
        };

        try {
            const data = await requestJson(`${API}/api/tickets/simulate-ocr`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(body)
            });

            document.getElementById("ocrResponse").innerText = JSON.stringify(data, null, 2);

            await loadTickets();
            await loadClaims();
            await loadFraudAlerts();

        } catch (error) {
            document.getElementById("ocrResponse").innerText = JSON.stringify(error, null, 2);
            await loadFraudAlerts();
        }
    }

    async function approveClaim() {
        const claimId = document.getElementById("claimIdToApprove").value;

        if (!claimId) {
            alert("Entre l'ID du claim à approuver.");
            return;
        }

        try {
            await requestJson(`${API}/api/claims/${claimId}/status?status=APPROVED`, {
                method: "PUT"
            });

            alert("Claim approuvé avec succès.");
            await loadClaims();
            await loadDashboard();

        } catch (error) {
            alert("Erreur approbation claim : " + JSON.stringify(error));
        }
    }

    async function runCashbackBatch() {
        try {
            const data = await requestJson(`${API}/api/cashback/batch/run`, {
                method: "POST"
            });

            document.getElementById("batchResponse").innerText = JSON.stringify(data, null, 2);

            await loadClaims();
            await loadPayments();
            await loadDashboard();

        } catch (error) {
            document.getElementById("batchResponse").innerText = JSON.stringify(error, null, 2);
        }
    }

    async function refreshAll() {
        await loadDashboard();
        await loadMerchants();
        await loadProducts();
        await loadCampaigns();
        await loadTickets();
        await loadClaims();
        await loadPayments();
        await loadFraudAlerts();
    }

    loadDashboard();
</script>

</body>
</html>