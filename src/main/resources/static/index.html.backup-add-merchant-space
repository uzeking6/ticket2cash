<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ticket2Cash - Admin Portal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        :root {
            --sidebar-width: 230px;
            --topbar-height: 66px;
            --bg: #F4F6F9;
            --white: #FFFFFF;
            --black: #111111;
            --text: #222222;
            --muted: #6B7280;
            --border: #E5E7EB;
            --active: #E5E7EB;
            --red: #D22630;
            --red-dark: #9F1C24;
            --gold: #FFCC00;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--bg);
            color: var(--text);
            font-family: "Segoe UI", Arial, sans-serif;
            font-size: 14px;
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-width);
            background: var(--white);
            border-right: 1px solid #DADDE2;
            overflow-y: auto;
            z-index: 1000;
        }

        .brand {
            height: 66px;
            background: #000000;
            display: flex;
            align-items: center;
            padding: 0 16px;
        }

        .brand img {
            max-width: 150px;
            max-height: 46px;
            object-fit: contain;
        }

        .brand-fallback {
            color: white;
            font-size: 20px;
            font-weight: 900;
        }

        .menu-label {
            padding: 13px 16px 8px 16px;
            font-size: 11px;
            font-weight: 900;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .menu-btn {
            width: 100%;
            height: 39px;
            display: flex;
            align-items: center;
            gap: 12px;
            border: none;
            border-left: 4px solid transparent;
            background: var(--white);
            color: #222222;
            padding: 0 14px 0 22px;
            text-align: left;
            font-weight: 700;
            cursor: pointer;
        }

        .menu-btn:hover {
            background: #F0F1F3;
            border-left-color: #111111;
        }

        .menu-btn.active {
            background: var(--active);
            border-left-color: #111111;
            font-weight: 900;
        }

        .menu-icon {
            width: 18px;
            min-width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #111111;
        }

        .menu-icon svg {
            width: 17px;
            height: 17px;
            stroke: currentColor;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            height: var(--topbar-height);
            background: var(--white);
            border-bottom: 1px solid var(--border);
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            padding: 0 24px;
            z-index: 900;
        }

        .top-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-info {
            color: #374151;
            font-size: 13px;
        }

        .logout-btn {
            background: white;
            color: #111111;
            border: 2px solid #111111;
            padding: 7px 13px;
            font-weight: 900;
            cursor: pointer;
        }

        .logout-btn:hover {
            background: #111111;
            color: white;
        }

        .page-title-top {
            font-size: 16px;
            font-weight: 900;
            color: #111111;
            text-align: center;
        }

        .top-logo {
            justify-self: end;
        }

        .top-logo img {
            max-height: 46px;
            max-width: 230px;
            object-fit: contain;
        }

        main {
            margin-left: var(--sidebar-width);
            padding: 88px 26px 32px 26px;
            min-height: 100vh;
        }

        .page {
            display: none;
        }

        .page.active {
            display: block;
        }

        .hero {
            background: white;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 22px;
            margin-bottom: 20px;
        }

        .hero h1 {
            margin: 0 0 10px 0;
            font-size: 26px;
            color: #111111;
        }

        .hero p {
            margin: 0;
            color: #111111;
            line-height: 1.6;
        }

        .kpis {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 14px;
            margin-bottom: 20px;
        }

        .kpi {
            background: white;
            border: 1px solid var(--border);
            padding: 16px;
        }

        .kpi-label {
            color: #52627A;
            font-size: 13px;
            margin-bottom: 8px;
        }

        .kpi-value {
            font-size: 25px;
            font-weight: 900;
            color: #000000;
        }

        .panel {
            background: white;
            border: 1px solid var(--border);
            padding: 18px;
            margin-bottom: 18px;
        }

        .panel-title {
            margin: 0 0 14px 0;
            font-size: 19px;
            color: #111111;
            font-weight: 900;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--border);
        }

        .operation-panel {
            background: white;
            border: 1px solid #DADDE2;
            border-left: 5px solid #111111;
            padding: 14px 16px;
            margin-bottom: 18px;
            position: sticky;
            top: 76px;
            z-index: 80;
        }

        .operation-title {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 900;
            color: #111111;
            margin-bottom: 12px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 12px;
            margin-bottom: 12px;
        }

        label {
            font-size: 12px;
            font-weight: 800;
            display: block;
            margin-bottom: 4px;
            color: #374151;
        }

        input, select, textarea {
            width: 100%;
            padding: 9px 10px;
            border: 1px solid #D1D5DB;
            background: white;
            color: #111111;
            font-family: inherit;
        }

        textarea {
            min-height: 82px;
        }

        .btn {
            border: none;
            padding: 10px 14px;
            cursor: pointer;
            font-weight: 900;
            margin: 3px;
        }

        .btn-primary {
            background: var(--red);
            color: white;
        }

        .btn-secondary {
            background: var(--gold);
            color: #111111;
        }

        .btn-dark {
            background: #111111;
            color: white;
        }

        .btn-danger {
            background: var(--red-dark);
            color: white;
        }

        .btn-light {
            background: #F3F4F6;
            color: #111111;
            border: 1px solid #D1D5DB;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            border: 1px solid var(--border);
            margin-top: 12px;
        }

        th {
            background: #111111;
            color: white;
            text-align: left;
            padding: 10px;
            font-size: 12px;
            border-bottom: 3px solid var(--gold);
        }

        td {
            padding: 9px;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
            vertical-align: top;
        }

        tr:nth-child(even) td {
            background: #FAFAFA;
        }

        .response {
            background: #111111;
            color: white;
            padding: 14px;
            border-left: 5px solid var(--gold);
            white-space: pre-wrap;
            overflow-x: auto;
            font-family: Consolas, monospace;
            font-size: 12px;
            margin-top: 12px;
        }

        .about-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
            margin-bottom: 18px;
        }

        .about-card {
            background: white;
            border: 1px solid var(--border);
            border-top: 4px solid #111111;
            padding: 18px;
        }

        .about-card.red {
            border-top-color: var(--red);
        }

        .about-card.gold {
            border-top-color: var(--gold);
        }

        .about-card h3 {
            margin: 0 0 10px 0;
            font-size: 17px;
        }

        .about-card p, .about-card li {
            color: #374151;
            line-height: 1.55;
        }

        .hidden {
            display: none !important;
        }

        @media (max-width: 820px) {
            .sidebar {
                position: relative;
                width: 100%;
                height: auto;
            }

            .topbar {
                left: 0;
                grid-template-columns: 1fr;
            }

            .top-left, .top-logo {
                display: none;
            }

            main {
                margin-left: 0;
                padding: 88px 12px 24px 12px;
            }

            .operation-panel {
                position: static;
            }
        }
    </style>

<style id="t2c-cdc-compliance-style">
    .cdc-status {
        display: inline-block;
        min-width: 120px;
        padding: 5px 8px;
        font-size: 12px;
        font-weight: 900;
        text-align: center;
    }

    .cdc-ok {
        background: #E7F7EE;
        color: #116B3A;
        border: 1px solid #9AD8B5;
    }

    .cdc-partial {
        background: #FFF8D6;
        color: #7A5A00;
        border: 1px solid #E8C64A;
    }

    .cdc-no {
        background: #FDECEE;
        color: #9F1C24;
        border: 1px solid #F0A8AE;
    }

    .cdc-phase {
        background: #F3F4F6;
        color: #111111;
        border: 1px solid #D1D5DB;
    }

    .cdc-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .cdc-summary-card {
        background: white;
        border: 1px solid #E5E7EB;
        border-left: 5px solid #111111;
        padding: 16px;
    }

    .cdc-summary-card.red {
        border-left-color: #D22630;
    }

    .cdc-summary-card.gold {
        border-left-color: #FFCC00;
    }

    .cdc-summary-card h3 {
        margin: 0 0 8px 0;
        font-size: 16px;
        color: #111111;
    }

    .cdc-summary-card .value {
        font-size: 25px;
        font-weight: 900;
    }

    .cdc-note {
        background: #FFF8D6;
        border: 1px solid #E8C64A;
        border-left: 5px solid #FFCC00;
        padding: 14px;
        margin-bottom: 18px;
        line-height: 1.55;
    }
</style>


<style id="t2c-finance-reconciliation-style">
    .finance-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
        gap: 14px;
        margin-bottom: 20px;
    }

    .finance-card {
        background: white;
        border: 1px solid #E5E7EB;
        border-left: 5px solid #111111;
        padding: 16px;
    }

    .finance-card.red {
        border-left-color: #D22630;
    }

    .finance-card.gold {
        border-left-color: #FFCC00;
    }

    .finance-card .label {
        color: #52627A;
        font-size: 13px;
        margin-bottom: 8px;
    }

    .finance-card .value {
        font-size: 23px;
        font-weight: 900;
        color: #111111;
    }

    .finance-note {
        background: #FFF8D6;
        border: 1px solid #E8C64A;
        border-left: 5px solid #FFCC00;
