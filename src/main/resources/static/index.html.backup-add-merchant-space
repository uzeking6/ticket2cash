                try {
                    return await api(path);
                } catch (e) {
                    console.warn("Erreur API dashboard:", path, e);
                    return null;
                }
            }

            const summary = await safeApi("/api/dashboard/summary");
            const merchantsData = await safeApi("/api/merchants");
            const productsData = await safeApi("/api/products");
            const claimsData = await safeApi("/api/claims");
            const paymentsData = await safeApi("/api/cashback/payments");

            const merchantsArray = asArray(merchantsData);
            const productsArray = asArray(productsData);
            const claimsArray = asArray(claimsData);
            const paymentsArray = asArray(paymentsData);

            const merchantsFromSummary = pickNumber(summary, [
                "commercantsPartenaires",
                "commercants",
                "merchants",
                "totalMerchants",
                "merchantCount",
                "merchantsCount",
                "nombreCommercants"
            ]);

            const productsFromSummary = pickNumber(summary, [
                "produits",
                "products",
                "totalProducts",
                "productCount",
                "productsCount",
                "nombreProduits"
            ]);

            const claimsFromSummary = pickNumber(summary, [
                "claims",
                "totalClaims",
                "claimCount",
                "claimsCount",
                "nombreClaims"
            ]);

            const cashbackFromSummary = pickNumber(summary, [
                "cashbackPaye",
                "cashbackPaid",
                "totalCashbackPaid",
                "totalPaidCashback",
                "montantCashbackPaye",
                "totalCashback"
            ]);

            const cashbackFromPayments = paymentsArray
                .filter(function (p) {
                    return !p.status || p.status === "SUCCESS" || p.status === "PAID";
                })
                .reduce(function (sum, p) {
                    return sum + amountOf(p);
                }, 0);

            const merchants = Math.max(merchantsFromSummary, merchantsArray.length);
            const products = Math.max(productsFromSummary, productsArray.length);
            const claims = Math.max(claimsFromSummary, claimsArray.length);
            const cashback = Math.max(cashbackFromSummary, cashbackFromPayments);

            const kpiHtml =
