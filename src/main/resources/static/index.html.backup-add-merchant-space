<script id="t2c-finance-refresh-final-fix">
(function () {
    function asArray(data) {
        if (!data) return [];
        if (Array.isArray(data)) return data;
        if (Array.isArray(data.content)) return data.content;
        if (Array.isArray(data.items)) return data.items;
        if (Array.isArray(data.data)) return data.data;
        if (Array.isArray(data.results)) return data.results;

        for (const key in data) {
            if (Array.isArray(data[key])) return data[key];
        }

        return [];
    }

    function toNumber(value) {
        if (value === null || value === undefined || value === "") return 0;
        const n = Number(String(value).replace(",", "."));
        return Number.isNaN(n) ? 0 : n;
    }

    function formatMoney(value) {
        return toNumber(value).toLocaleString("fr-FR") + " FCFA";
    }

    function getAmount(obj) {
        return toNumber(
            obj?.amount ??
            obj?.montant ??
            obj?.ticketAmount ??
            obj?.totalAmount ??
            obj?.cashbackAmount ??
            obj?.cashback ??
            obj?.value
        );
    }

    async function safeFetchJson(url) {
        try {
            const response = await fetch(url, {
                method: "GET",
                credentials: "same-origin",
                headers: { "Accept": "application/json" }
            });

            if (!response.ok) {
                console.warn("API non disponible:", url, response.status);
                return null;
            }

            return await response.json();
        } catch (e) {
            console.warn("Erreur appel API:", url, e);
            return null;
        }
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    }

    function renderFinanceTable(containerId, rows) {
        const el = document.getElementById(containerId);
        if (!el) return;

        let html = `
            <table>
                <thead>
                    <tr>
                        <th>Indicateur</th>
                        <th>Valeur</th>
                        <th>Observation</th>
                    </tr>
                </thead>
                <tbody>
        `;

        rows.forEach(function (r) {
            html += `
                <tr>
                    <td>${r.indicateur}</td>
                    <td>${r.valeur}</td>
                    <td>${r.observation || ""}</td>
                </tr>
            `;
        });

        html += `
                </tbody>
            </table>
        `;

        el.innerHTML = html;
    }

    async function computeFinanceClientSide() {
        const merchantsData = await safeFetchJson("/api/merchants");
        const productsData = await safeFetchJson("/api/products");
        const ticketsData = await safeFetchJson("/api/tickets");
        const claimsData = await safeFetchJson("/api/claims");
        const paymentsData = await safeFetchJson("/api/cashback/payments");

        const merchants = asArray(merchantsData);
        const products = asArray(productsData);
        const tickets = asArray(ticketsData);
        const claims = asArray(claimsData);
        const payments = asArray(paymentsData);

        let totalTicketVolume = tickets.reduce(function (sum, t) {
            return sum + getAmount(t);
        }, 0);

        if (totalTicketVolume === 0) {
            totalTicketVolume = claims.reduce(function (sum, c) {
                return sum + getAmount(c);
            }, 0);
        }

        const paidPayments = payments.filter(function (p) {
            const status = String(p.status || "").toUpperCase();
            return !status || status === "SUCCESS" || status === "PAID";
        });

        const totalCashbackPaid = paidPayments.reduce(function (sum, p) {
            return sum + getAmount(p);
        }, 0);

        const approvedClaims = claims.filter(function (c) {
            return String(c.status || "").toUpperCase() === "APPROVED";
        }).length;

        const paidClaims = claims.filter(function (c) {
            return String(c.status || "").toUpperCase() === "PAID";
        }).length;

        const rejectedClaims = claims.filter(function (c) {
            return String(c.status || "").toUpperCase() === "REJECTED";
        }).length;

        const mdr1 = totalTicketVolume * 0.01;
        const mdr15 = totalTicketVolume * 0.015;
        const successFees = totalCashbackPaid * 0.05;
        const bankRevenueMin = mdr1 + successFees;
        const bankRevenueMax = mdr15 + successFees;
        const reconciliationGap = Math.max(0, approvedClaims - paidPayments.length);

        return {
            totalMerchants: merchants.length,
            totalProducts: products.length,
            totalTickets: tickets.length,
            totalClaims: claims.length,
            approvedClaims: approvedClaims,
            paidClaims: paidClaims,
            rejectedClaims: rejectedClaims,
            totalPayments: payments.length,
            successPayments: paidPayments.length,
            totalTicketVolume: totalTicketVolume,
            totalCashbackPaid: totalCashbackPaid,
            successFeesFivePercent: successFees,
            estimatedBankRevenueMin: bankRevenueMin,
            estimatedBankRevenueMax: bankRevenueMax,
            reconciliationGap: reconciliationGap
        };
    }

    window.loadFinanceReconciliation = async function () {
        const financeTable = document.getElementById("financeTable");
        const financeDetails = document.getElementById("financeDetails");

        if (financeTable) {
            financeTable.innerHTML = "<p>Chargement de la reconciliation finance...</p>";
        }

        let data = await safeFetchJson("/api/finance/reconciliation/summary");

        if (!data || !data.rows) {
            data = await computeFinanceClientSide();

            data.rows = [
                {
                    indicateur: "Volume transactions estime",
                    valeur: formatMoney(data.totalTicketVolume),
                    observation: "Calcule depuis les tickets ou claims disponibles"
                },
                {
                    indicateur: "Cashback paye",
                    valeur: formatMoney(data.totalCashbackPaid),
                    observation: "Somme des paiements SUCCESS / PAID"
                },
                {
                    indicateur: "MDR estime 1%",
                    valeur: formatMoney(data.totalTicketVolume * 0.01),
                    observation: "Hypothese basse du modele economique"
                },
                {
                    indicateur: "MDR estime 1.5%",
                    valeur: formatMoney(data.totalTicketVolume * 0.015),
                    observation: "Hypothese haute du modele economique"
                },
                {
                    indicateur: "Success fees 5%",
                    valeur: formatMoney(data.successFeesFivePercent),
                    observation: "Commission banque sur cashback paye"
                },
                {
                    indicateur: "Revenus banque min",
                    valeur: formatMoney(data.estimatedBankRevenueMin),
                    observation: "MDR 1% + success fees"
                },
                {
                    indicateur: "Revenus banque max",
                    valeur: formatMoney(data.estimatedBankRevenueMax),
                    observation: "MDR 1.5% + success fees"
                },
                {
                    indicateur: "Ecart reconciliation",
                    valeur: data.reconciliationGap,
                    observation: "Claims approuves non rapproches aux paiements"
                }
            ];
        }

        setText("financeVolume", formatMoney(data.totalTicketVolume));
        setText("financeCashbackPaid", formatMoney(data.totalCashbackPaid));
        setText("financeSuccessFees", formatMoney(data.successFeesFivePercent));
        setText(
            "financeBankRevenue",
            formatMoney(data.estimatedBankRevenueMin) + " - " + formatMoney(data.estimatedBankRevenueMax)
        );

        renderFinanceTable("financeTable", data.rows || []);

        renderFinanceTable("financeDetails", [
            { indicateur: "Commercants", valeur: data.totalMerchants, observation: "Partenaires enregistres" },
            { indicateur: "Produits", valeur: data.totalProducts, observation: "Articles / produits disponibles" },
            { indicateur: "Tickets", valeur: data.totalTickets, observation: "Tickets remontes ou simules" },
            { indicateur: "Claims", valeur: data.totalClaims, observation: "Demandes cashback" },
            { indicateur: "Claims approuves", valeur: data.approvedClaims, observation: "En attente ou deja traites" },
            { indicateur: "Claims payes", valeur: data.paidClaims, observation: "Statut PAID" },
            { indicateur: "Paiements SUCCESS", valeur: data.successPayments, observation: "Paiements cashback reussis" },
            { indicateur: "Total paiements", valeur: data.totalPayments, observation: "Tous statuts confondus" },
            { indicateur: "Ecart reconciliation", valeur: data.reconciliationGap, observation: "Point de controle comptable" }
        ]);
    };

    document.addEventListener("DOMContentLoaded", function () {
        const financeBtn = Array.from(document.querySelectorAll("button")).find(function (btn) {
            return (btn.textContent || "").toLowerCase().includes("actualiser finance");
        });

        if (financeBtn) {
            financeBtn.onclick = window.loadFinanceReconciliation;
        }
    });
})();
</script>


<script id="t2c-card-stock-js">
(function () {
