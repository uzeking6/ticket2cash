<script id="t2c-card-stock-data-final-fix">
(function () {
    function asArray(data) {
        if (!data) return [];
        if (Array.isArray(data)) return data;
        if (Array.isArray(data.rows)) return data.rows;
        if (Array.isArray(data.content)) return data.content;
        if (Array.isArray(data.items)) return data.items;
        if (Array.isArray(data.data)) return data.data;
        if (Array.isArray(data.results)) return data.results;

        for (const key in data) {
            if (Array.isArray(data[key])) return data[key];
        }

        return [];
    }

    async function safeJson(url, options) {
        try {
            const response = await fetch(url, Object.assign({
                credentials: "same-origin",
                headers: { "Accept": "application/json" }
            }, options || {}));

            if (!response.ok) {
                console.warn("API stock cartes non disponible:", url, response.status);
                return null;
            }

            const type = response.headers.get("content-type") || "";
            if (type.includes("application/json")) {
                return await response.json();
            }

            return null;
        } catch (e) {
            console.warn("Erreur API stock cartes:", url, e);
            return null;
        }
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    }

    function statusBadge(status) {
        const s = String(status || "").toUpperCase();

        if (s === "OK") {
            return '<span class="stock-status stock-ok">OK</span>';
        }

        if (s === "LOW_STOCK") {
            return '<span class="stock-status stock-low">Stock faible</span>';
        }

        return '<span class="stock-status stock-low">Sans stock</span>';
    }

    function normalizeRows(rows) {
        return rows.map(function (r, index) {
            const received = Number(r.cardsReceived ?? r.recues ?? r.received ?? 0);
            const distributed = Number(r.cardsDistributed ?? r.distribuees ?? r.distributed ?? 0);
            const remaining = Number(r.remainingCards ?? r.cartesRestantes ?? r.remaining ?? Math.max(received - distributed, 0));
            const threshold = Number(r.alertThreshold ?? r.seuil ?? 200);
            const status = r.stockStatus || (remaining <= threshold ? "LOW_STOCK" : "OK");

            return {
                id: r.id ?? ("demo-" + index),
                merchantName: r.merchantName || r.brandName || r.name || ("Commercant " + (index + 1)),
                cardsReceived: received,
                cardsDistributed: distributed,
                remainingCards: remaining,
                alertThreshold: threshold,
                stockStatus: status,
                isDemo: String(r.id ?? "").startsWith("demo-") || !r.id
            };
        });
    }

    function demoRowsFromMerchants(merchants) {
        const source = merchants.length > 0 ? merchants : [
            { name: "Supermarche Partenaire A" },
            { name: "Supermarche Partenaire B" },
            { name: "Supermarche Partenaire C" }
        ];

        return source.slice(0, 5).map(function (m, index) {
            const received = 1000 + (index * 250);
            const distributed = 300 + (index * 120);
            const remaining = received - distributed;
            const threshold = 200;

            return {
                id: "demo-" + index,
                merchantName: m.brandName || m.name || m.merchantName || ("Commercant " + (index + 1)),
                cardsReceived: received,
                cardsDistributed: distributed,
                remainingCards: remaining,
                alertThreshold: threshold,
                stockStatus: remaining <= threshold ? "LOW_STOCK" : "OK",
                isDemo: true
            };
        });
    }

    function renderCardStockRows(rows) {
        const el = document.getElementById("cardStockTable");
        if (!el) return;

        if (!rows || rows.length === 0) {
            el.innerHTML = "<p>Aucune donnee stock carte disponible.</p>";
            return;
        }

        let html = `
            <table>
                <thead>
                    <tr>
                        <th>Commercant</th>
                        <th>Recues</th>
                        <th>Distribuees</th>
                        <th>Restantes</th>
                        <th>Seuil</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
        `;

        rows.forEach(function (r) {
            let actions = '<span style="font-weight:800;color:#52627A;">Simulation</span>';

            if (!String(r.id).startsWith("demo-")) {
                actions = `
                    <button class="btn btn-primary" onclick="distributeCards(${r.id}, 10)">+10</button>
                    <button class="btn btn-dark" onclick="distributeCards(${r.id}, 50)">+50</button>
                    <button class="btn btn-dark" onclick="deleteCardStock(${r.id})">Supprimer</button>
                `;
            }

            html += `
                <tr>
                    <td>${r.merchantName || ""}</td>
                    <td>${r.cardsReceived}</td>
                    <td>${r.cardsDistributed}</td>
                    <td><strong>${r.remainingCards}</strong></td>
                    <td>${r.alertThreshold}</td>
                    <td>${statusBadge(r.stockStatus)}</td>
                    <td>${actions}</td>
                </tr>
            `;
        });

        html += `
                </tbody>
            </table>
        `;

        el.innerHTML = html;
    }

    function updateStockKpis(rows) {
        const totalReceived = rows.reduce((s, r) => s + Number(r.cardsReceived || 0), 0);
        const totalDistributed = rows.reduce((s, r) => s + Number(r.cardsDistributed || 0), 0);
        const totalRemaining = rows.reduce((s, r) => s + Number(r.remainingCards || 0), 0);
        const lowStockCount = rows.filter(function (r) {
            return String(r.stockStatus || "").toUpperCase() !== "OK";
        }).length;

        setText("stockReceived", totalReceived);
        setText("stockDistributed", totalDistributed);
        setText("stockRemaining", totalRemaining);
        setText("stockLowCount", lowStockCount);
    }

    window.loadCardStocks = async function () {
        const table = document.getElementById("cardStockTable");
        if (table) table.innerHTML = "<p>Chargement des stocks cartes...</p>";

        let summary = await safeJson("/api/card-stocks/summary");
        let rows = normalizeRows(asArray(summary));

        if (rows.length === 0) {
            await safeJson("/api/card-stocks/init-demo", { method: "POST" });

            summary = await safeJson("/api/card-stocks/summary");
            rows = normalizeRows(asArray(summary));
        }

        if (rows.length === 0) {
            const merchantsData = await safeJson("/api/merchants");
            const merchants = asArray(merchantsData);
            rows = normalizeRows(demoRowsFromMerchants(merchants));
        }

        updateStockKpis(rows);
        renderCardStockRows(rows);
    };

    window.initCardStockDemo = async function () {
        const table = document.getElementById("cardStockTable");
        if (table) table.innerHTML = "<p>Initialisation des stocks cartes...</p>";

        await safeJson("/api/card-stocks/init-demo", { method: "POST" });
        await window.loadCardStocks();
    };

    window.distributeCards = async function (id, quantity) {
        await safeJson("/api/card-stocks/" + id + "/distribute?quantity=" + quantity, {
            method: "PUT"
        });

        await window.loadCardStocks();
    };

    window.deleteCardStock = async function (id) {
        if (!confirm("Supprimer ce stock carte ?")) return;

        await safeJson("/api/card-stocks/" + id, {
            method: "DELETE"
        });

        await window.loadCardStocks();
    };

    document.addEventListener("DOMContentLoaded", function () {
        const btn = Array.from(document.querySelectorAll("button")).find(function (b) {
            return (b.textContent || "").toLowerCase().includes("actualiser stock");
        });

        if (btn) {
            btn.onclick = window.loadCardStocks;
        }
    });
})();
</script>


<script id="t2c-pos-api-js">
(function () {
    let lastTicketNumber = "";

    function posIcon() {
        return '<svg viewBox="0 0 24 24"><path d="M4 5h16v14H4V5z"></path><path d="M8 9h8"></path><path d="M8 13h4"></path><path d="M15 13h1"></path></svg>';
    }

    function asArray(data) {
        if (!data) return [];
        if (Array.isArray(data)) return data;
        if (Array.isArray(data.content)) return data.content;
        if (Array.isArray(data.items)) return data.items;
        if (Array.isArray(data.data)) return data.data;
        if (Array.isArray(data.results)) return data.results;
        if (Array.isArray(data.endpoints)) return data.endpoints;

        for (const key in data) {
            if (Array.isArray(data[key])) return data[key];
        }

        return [];
    }

    function money(value) {
        const n = Number(String(value || 0).replace(",", "."));
        if (Number.isNaN(n)) return "0 FCFA";
        return n.toLocaleString("fr-FR") + " FCFA";
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
    }

    function showResponse(data) {
        const el = document.getElementById("posResponse");
        if (el) el.textContent = JSON.stringify(data, null, 2);
    }

    async function posRequest(url, options) {
        options = options || {};

        const headers = Object.assign(
            { "Accept": "application/json" },
            options.headers || {}
        );

        if (options.body && !headers["Content-Type"]) {
            headers["Content-Type"] = "application/json";
        }

        const response = await fetch(url, Object.assign({}, options, {
            credentials: "same-origin",
            headers: headers
        }));

        const type = response.headers.get("content-type") || "";

        if (!response.ok) {
            const text = await response.text();
            throw new Error("Erreur API " + response.status + " : " + text);
        }

        if (type.includes("application/json")) {
            return await response.json();
        }

        return await response.text();
    }

    function readPayload() {
        return {
            clientReference: document.getElementById("posClientReference").value || "CLIENT-DEMO-001",
            cardNumber: document.getElementById("posCardNumber").value || "4578123412349876",
            merchantId: Number(document.getElementById("posMerchantId").value || 1),
            merchantName: document.getElementById("posMerchantName").value || "Supermarche Demo",
            totalAmount: Number(document.getElementById("posTotalAmount").value || 0),
            posId: document.getElementById("posIdInput").value || "POS-YDE-001",
            cashierId: "CAISSE-001",
            currency: "FCFA",
            items: [
                {
                    sku: "SKU-DEMO-001",
                    designation: "Riz parfume 5KG",
                    quantity: 1,
                    unitPrice: 12500,
                    cashbackAmount: 625
                },
                {
                    sku: "SKU-DEMO-002",
                    designation: "Huile vegetale 5L",
                    quantity: 1,
                    unitPrice: 16000,
                    cashbackAmount: 800
                }
            ]
        };
    }

    window.posVerifyCard = async function () {
        try {
            const payload = readPayload();

            const data = await posRequest("/api/v1/card/verify", {
                method: "POST",
                body: JSON.stringify({
                    cardNumber: payload.cardNumber,
                    clientReference: payload.clientReference
                })
            });

            setText("posClient", data.clientReference || payload.clientReference);
            showResponse(data);
        } catch (e) {
            showResponse({ error: e.message });
        }
    };

    window.posSubmitTicket = async function () {
        try {
            const payload = readPayload();

            const data = await posRequest("/api/v1/ticket/upload", {
                method: "POST",
                body: JSON.stringify(payload)
            });

            lastTicketNumber = data.ticketNumber || "";
            setText("posLastTicket", lastTicketNumber || "-");
            setText("posCashback", money(data.cashbackEstimated));
            setText("posStatus", data.status || "-");
            setText("posClient", data.clientReference || payload.clientReference);

            showResponse(data);
            await window.posLoadHistory();
        } catch (e) {
            showResponse({ error: e.message });
        }
    };

    window.posCheckStatus = async function () {
        try {
            if (!lastTicketNumber) {
                lastTicketNumber = document.getElementById("posLastTicket").textContent;
            }

            if (!lastTicketNumber || lastTicketNumber === "-") {
                showResponse({ error: "Aucun ticket POS encore soumis." });
                return;
            }

            const data = await posRequest("/api/v1/cashback/status/" + encodeURIComponent(lastTicketNumber));

            setText("posStatus", data.status || "-");
            setText("posCashback", money(data.cashbackEstimated));
            showResponse(data);
        } catch (e) {
            showResponse({ error: e.message });
        }
    };

    window.posLoadHistory = async function () {
        try {
            const clientReference = document.getElementById("posClientReference").value || "CLIENT-DEMO-001";
            const data = await posRequest("/api/v1/transaction/history/" + encodeURIComponent(clientReference));

            const rows = asArray(data);

            if (typeof renderTable === "function") {
                renderTable("posHistoryTable", rows);
            } else {
                document.getElementById("posHistoryTable").innerHTML = "<pre>" + JSON.stringify(rows, null, 2) + "</pre>";
            }

            showResponse(data);
        } catch (e) {
            showResponse({ error: e.message });
        }
    };

    window.posLoadProducts = async function () {
        try {
            const merchantId = document.getElementById("posMerchantId").value || "1";
            const data = await posRequest("/api/v1/merchant/products/" + encodeURIComponent(merchantId));
            const rows = asArray(data);

            if (typeof renderTable === "function") {
                renderTable("posProductsTable", rows);
            } else {
                document.getElementById("posProductsTable").innerHTML = "<pre>" + JSON.stringify(rows, null, 2) + "</pre>";
            }

            showResponse(data);
        } catch (e) {
            showResponse({ error: e.message });
        }
    };

    window.posLoadDocs = async function () {
        try {
            const data = await posRequest("/api/v1/docs");
            const rows = asArray(data.endpoints);

            if (typeof renderTable === "function") {
                renderTable("posHistoryTable", rows);
            }

            showResponse(data);
        } catch (e) {
            showResponse({ error: e.message });
        }
    };

    function showPosApi() {
        document.querySelectorAll(".page").forEach(function (p) {
            p.classList.remove("active");
        });

        document.querySelectorAll(".menu-btn").forEach(function (b) {
            b.classList.remove("active");
        });

        const page = document.getElementById("posApi");
        if (page) page.classList.add("active");

        const btn = document.querySelector('.menu-btn[data-page="posApi"]');
        if (btn) btn.classList.add("active");

        const title = document.getElementById("topTitle");
        if (title) title.textContent = "API POS Supermarches";

        window.scrollTo(0, 0);
    }

    function addPosMenu() {
        const sidebar = document.querySelector(".sidebar");
        if (!sidebar) return;

        if (sidebar.querySelector('.menu-btn[data-page="posApi"]')) return;

        const btn = document.createElement("button");
        btn.className = "menu-btn";
        btn.dataset.page = "posApi";
        btn.innerHTML = '<span class="menu-icon">' + posIcon() + '</span><span>API POS</span>';
        btn.addEventListener("click", showPosApi);

        const ticketsBtn = sidebar.querySelector('.menu-btn[data-page="tickets"]');
        if (ticketsBtn && ticketsBtn.nextSibling) {
            sidebar.insertBefore(btn, ticketsBtn.nextSibling);
        } else if (ticketsBtn) {
            sidebar.appendChild(btn);
        } else {
            sidebar.appendChild(btn);
        }
    }

    window.showPosApi = showPosApi;

    document.addEventListener("DOMContentLoaded", function () {
        addPosMenu();
    });

    setTimeout(addPosMenu, 700);
    setTimeout(addPosMenu, 1500);
})();
</script>


