        function money(v) {
            if (v === null || v === undefined) return "0";
            return String(v);
        }

        function setResponse(id, data) {
            const el = document.getElementById(id);
            if (el) el.textContent = typeof data === "string" ? data : JSON.stringify(data, null, 2);
