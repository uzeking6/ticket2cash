<script id="ticket2cash-dashboard-kpi-fixed-ids">
(function () {
    function asArray(data) {
        if (!data) return [];
        if (Array.isArray(data)) return data;
        if (Array.isArray(data.content)) return data.content;
        if (Array.isArray(data.items)) return data.items;
        if (Array.isArray(data.data)) return data.data;
        if (Array.isArray(data.results)) return data.results;

        // Recherche recursive d'un tableau dans l'objet si le backend retourne une structure differente
        for (const key in data) {
            if (!Object.prototype.hasOwnProperty.call(data, key)) continue;
            if (Array.isArray(data[key])) return data[key];
        }

        return [];
    }

    function toNumber(value) {
        if (value === null || value === undefined || value === "") return 0;
        const n = Number(value);
        return Number.isNaN(n) ? 0 : n;
    }

    function amountOf(payment) {
        return toNumber(
            payment.amount ??
            payment.montant ??
            payment.cashbackAmount ??
            payment.cashback ??
            payment.totalAmount ??
            payment.value
        );
    }

    function formatFcfa(value) {
        return toNumber(value).toLocaleString("fr-FR") + " FCFA";
    }

    async function getJson(url) {
        const response = await fetch(url, {
            method: "GET",
            credentials: "same-origin",
            headers: { "Accept": "application/json" }
        });

        if (!response.ok) {
            console.warn("Erreur API:", url, response.status);
            return null;
        }

        return await response.json();
    }

    function setText(id, value) {
        const el = document.getElementById(id);
        if (el) {
            el.textContent = value;
        }
    }

    async function computeDashboardKpis() {
        const merchantsData = await getJson("/api/merchants");
        const productsData = await getJson("/api/products");
        const claimsData = await getJson("/api/claims");
        const paymentsData = await getJson("/api/cashback/payments");

        const merchants = asArray(merchantsData);
        const products = asArray(productsData);
        const claims = asArray(claimsData);
        const payments = asArray(paymentsData);

        const totalCashbackPaid = payments
            .filter(function (p) {
                return !p.status || p.status === "SUCCESS" || p.status === "PAID";
            })
            .reduce(function (sum, p) {
                return sum + amountOf(p);
            }, 0);

        return {
            merchants: merchants.length,
            products: products.length,
            claims: claims.length,
            payments: payments.length,
            cashback: totalCashbackPaid
        };
    }

    window.loadDashboard = async function () {
        const values = await computeDashboardKpis();

        setText("kpiMerchants", values.merchants);
        setText("kpiProducts", values.products);
        setText("kpiClaims", values.claims);
        setText("kpiCashback", formatFcfa(values.cashback));

        renderTable("dashboardTable", [
            { indicateur: "Commercants partenaires", valeur: values.merchants },
            { indicateur: "Produits", valeur: values.products },
            { indicateur: "Claims", valeur: values.claims },
            { indicateur: "Paiements cashback", valeur: values.payments },
            { indicateur: "Cashback paye", valeur: formatFcfa(values.cashback) }
        ]);
    };

    document.addEventListener("DOMContentLoaded", function () {
        setTimeout(function () {
            const dashboard = document.getElementById("dashboard");
            if (dashboard && dashboard.classList.contains("active")) {
                window.loadDashboard();
            }
        }, 500);
    });
})();
</script>


